generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(uuid())
  firstName            String
  lastName             String
  email                String         @unique
  passwordHash         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  googleId             String?        @unique
  authProvider         String         @default("local")
  dob                  DateTime?
  gender               String?
  onboardingComplete   Boolean        @default(false)
  bio                  String?
  city                 String?
  phone                String?
  profilePicture       String?
  primaryRole          String?
  sports               String[]       @default([])
  orgMemberships       OrgMember[]
  partnerRegistrations Registration[] @relation("PartnerRegistrations")
  registrations        Registration[] @relation("UserRegistrations")

  @@map("users")
}

model Organization {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  logoUrl     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     OrgMember[]
  tournaments Tournament[]

  @@map("organizations")
}

model OrgMember {
  id        String       @id @default(uuid())
  userId    String
  orgId     String
  role      OrgRole      @default(MEMBER)
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("org_members")
}

model Tournament {
  id                   String           @id @default(uuid())
  organizationId       String
  name                 String
  sport                String
  startDate            DateTime
  endDate              DateTime
  venueName            String
  venueAddress         String?
  city                 String
  registrationDeadline DateTime
  entryFee             Decimal?         @db.Decimal(10, 2)
  description          String?
  maxParticipants      Int?
  status               TournamentStatus @default(DRAFT)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  format               TournamentFormat @default(BRACKET)
  events               Event[]
  organization         Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tournaments")
}

model Event {
  id              String         @id @default(uuid())
  tournamentId    String
  name            String
  format          EventFormat
  maxParticipants Int?
  registrationFee Decimal?       @db.Decimal(10, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  category        String?
  gender          String?
  tournament      Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  registrations   Registration[]

  @@map("events")
}

model Registration {
  id        String             @id @default(uuid())
  userId    String
  eventId   String
  partnerId String?
  status    RegistrationStatus @default(CONFIRMED)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  partner   User?              @relation("PartnerRegistrations", fields: [partnerId], references: [id])
  user      User               @relation("UserRegistrations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("registrations")
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum TournamentFormat {
  BRACKET
  ROUND_ROBIN
  KNOCKOUT
  LEAGUE
}

enum TournamentStatus {
  DRAFT
  OPEN
  CLOSED
  ONGOING
  COMPLETED
}

enum EventFormat {
  SINGLES
  DOUBLES
  MIXED_DOUBLES
}

enum RegistrationStatus {
  CONFIRMED
  CANCELLED
}
