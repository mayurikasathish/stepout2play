generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(uuid())
  firstName            String
  lastName             String
  email                String         @unique
  passwordHash         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  googleId             String?        @unique
  authProvider         String         @default("local")
  dob                  DateTime?
  gender               String?
  onboardingComplete   Boolean        @default(false)
  bio                  String?
  city                 String?
  phone                String?
  profilePicture       String?
  primaryRole          String?
  sports               String[]       @default([])
  orgMemberships       OrgMember[]
  partnerRegistrations Registration[] @relation("PartnerRegistrations")
  registrations        Registration[] @relation("UserRegistrations")

  @@map("users")
}

model Organization {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  logoUrl     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     OrgMember[]
  tournaments Tournament[]

  @@map("organizations")
}

model OrgMember {
  id        String       @id @default(uuid())
  userId    String
  orgId     String
  role      OrgRole      @default(MEMBER)
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("org_members")
}

model Tournament {
  id                   String           @id @default(uuid())
  organizationId       String
  name                 String
  sport                String
  startDate            DateTime
  endDate              DateTime
  venueName            String
  venueAddress         String?
  city                 String
  registrationDeadline DateTime
  description          String?
  rules                String?
  status               TournamentStatus @default(DRAFT) // Organizer sets DRAFT/OPEN only. System calculates CLOSED/ONGOING/COMPLETED based on dates
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  format               TournamentFormat @default(BRACKET)
  breakDuration        Int?             @default(15)
  courtsAvailable      Int?             @default(4)
  dailyEndTime         String?
  dailyStartTime       String?
  firstMatchDate       DateTime?
  matchDuration        Int?             @default(45)
  minRestTime          Int?             @default(30)
  events               Event[]
  organization         Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tournaments")
}

model Event {
  id               String         @id @default(uuid())
  tournamentId     String
  name             String
  format           EventFormat
  maxParticipants  Int?
  registrationFee  Decimal?       @db.Decimal(10, 2)
  rules            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  category         String?
  gender           String?
  bracketFormat    BracketFormat?
  bracketGenerated Boolean        @default(false)
  seedingMethod    SeedingMethod?
  totalSlots       Int?           // Next power of 2 (e.g., 13 → 16)
  totalRounds      Int?           // log2(totalSlots)
  byeCount         Int?           // totalSlots - participantCount
  tournament       Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches          Match[]
  registrations    Registration[]

  @@map("events")
}

model Registration {
  id          String             @id @default(uuid())
  userId      String
  eventId     String
  partnerId   String?
  status      RegistrationStatus @default(CONFIRMED)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  seedNumber  Int?
  isWithdrawn Boolean            @default(false)
  withdrawnAt DateTime?
  matchesAsP1 Match[]            @relation("Match_Participant1")
  matchesAsP2 Match[]            @relation("Match_Participant2")
  matchesWon  Match[]            @relation("Match_Winner")
  event       Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  partner     User?              @relation("PartnerRegistrations", fields: [partnerId], references: [id])
  user        User               @relation("UserRegistrations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("registrations")
}

model Match {
  id             String        @id @default(uuid())
  eventId        String
  roundNumber    Int
  matchNumber    Int
  bracketPosition String?      // "R3-M1" for debugging/display
  participant1Id String?
  participant2Id String?
  winnerId       String?
  score          String?
  status         MatchStatus   @default(PENDING)
  nextMatchId    String?       // ID of match winner advances to
  feedsPosition  Int?          // 1 or 2 - which slot in nextMatch
  isByeMatch     Boolean       @default(false)
  isWalkover     Boolean       @default(false)
  scheduledAt    DateTime?
  completedAt    DateTime?
  courtNumber    Int?
  courtName      String?
  duration       Int?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  event          Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant1   Registration? @relation("Match_Participant1", fields: [participant1Id], references: [id])
  participant2   Registration? @relation("Match_Participant2", fields: [participant2Id], references: [id])
  winner         Registration? @relation("Match_Winner", fields: [winnerId], references: [id])

  @@unique([eventId, roundNumber, matchNumber])
  @@index([nextMatchId])
  @@index([status])
  @@index([scheduledAt])
  @@map("matches")
}

enum BracketFormat {
  SINGLE_ELIMINATION
  ROUND_ROBIN
}

enum SeedingMethod {
  REGISTRATION_ORDER
  RANDOM
  MANUAL
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum TournamentFormat {
  BRACKET
  ROUND_ROBIN
  KNOCKOUT
  LEAGUE
}

enum TournamentStatus {
  DRAFT
  OPEN
  CLOSED
  ONGOING
  COMPLETED
}

enum EventFormat {
  SINGLES
  DOUBLES
  MIXED_DOUBLES
}

enum RegistrationStatus {
  CONFIRMED
  CANCELLED
}

enum MatchStatus {
  PENDING      // Not yet played, waiting for participants
  READY        // Both participants known, can be played
  IN_PROGRESS  // Currently being played
  COMPLETED    // Finished with winner
  WALKOVER     // One player didn't show
  BYE          // Automatic advancement
  CANCELLED    // Match cancelled due to withdrawal
}
