generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(uuid())
  firstName            String
  lastName             String
  email                String         @unique
  passwordHash         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  googleId             String?        @unique
  authProvider         String         @default("local")
  dob                  DateTime?
  gender               String?
  onboardingComplete   Boolean        @default(false)
  bio                  String?
  city                 String?
  state                String?
  locality             String?
  latitude             Decimal?       @db.Decimal(10, 8)
  longitude            Decimal?       @db.Decimal(11, 8)
  phone                String?
  profilePicture       String?
  primaryRole          String?
  sports               String[]       @default([])
  isProfilePrivate     Boolean        @default(false)
  orgMemberships       OrgMember[]
  partnerRegistrations Registration[] @relation("PartnerRegistrations")
  registrations        Registration[] @relation("UserRegistrations")
  notifications        Notification[]
  liveFeedItems        LiveFeedItem[]
  playerRatings        PlayerRating[]
  following            Follow[]       @relation("UserFollowing")
  followers            Follow[]       @relation("UserFollowers")

  @@map("users")
}

model Organization {
  id                 String       @id @default(uuid())
  name               String
  slug               String       @unique
  logoUrl            String?
  tagline            String?
  description        String?
  bannerImageUrl     String?
  photoGallery       String[]     @default([])
  motto              String?
  aboutUs            String?
  whatWeOffer        String?
  joinUsInfo         String?
  membershipBenefits String?
  membershipFee      String?
  location           String?
  city               String?
  state              String?
  contactPerson      String?
  contactEmail       String?
  contactPhone       String?
  sports             String[]     @default([])
  instagramUrl       String?
  facebookUrl        String?
  twitterUrl         String?
  websiteUrl         String?
  socialLinks        Json?
  colorScheme        String?      @default("neon-arena")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  members            OrgMember[]
  tournaments        Tournament[]
  followers          OrgFollower[]
  joinRequests       OrgJoinRequest[]
  invitations        OrgInvitation[]

  @@map("organizations")
}

model OrgFollower {
  id        String       @id @default(uuid())
  userId    String
  orgId     String
  createdAt DateTime     @default(now())
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("org_followers")
}

model OrgJoinRequest {
  id         String       @id @default(uuid())
  userId     String
  orgId      String
  role       String       // MEMBER or ADMIN (requesting role)
  email      String
  reason     String
  experience String?
  status     String       @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("org_join_requests")
}

model OrgInvitation {
  id         String       @id @default(uuid())
  orgId      String
  inviterId  String       // User who sent the invite
  inviteeId  String       // User who received the invite
  role       String       // MEMBER or ADMIN
  message    String?
  status     String       @default("PENDING") // PENDING, ACCEPTED, DECLINED
  expiresAt  DateTime?    // Optional expiry date
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, inviteeId])
  @@map("org_invitations")
}

model OrgMember {
  id        String       @id @default(uuid())
  userId    String
  orgId     String
  role      OrgRole      @default(MEMBER)
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("org_members")
}

model Tournament {
  id                   String           @id @default(uuid())
  organizationId       String
  name                 String
  sport                String           // Legacy field - kept for backward compatibility
  sportType            String?          // "single" or "multi"
  sports               String[]         // Array of sport IDs (e.g., ["badminton", "table-tennis"])
  startDate            DateTime
  endDate              DateTime
  startTime            String?          // Tournament start time (HH:MM format)
  endTime              String?          // Tournament end time (HH:MM format)
  venueName            String
  venueAddress         String?
  city                 String
  state                String?
  latitude             Decimal?       @db.Decimal(10, 8)
  longitude            Decimal?       @db.Decimal(11, 8)
  registrationDeadline DateTime
  description          String?
  status               TournamentStatus @default(DRAFT)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  format               TournamentFormat @default(BRACKET)
  breakDuration        Int?             @default(15)
  courtsAvailable      Int?             @default(4)
  dailyEndTime         String?
  dailyStartTime       String?
  firstMatchDate       DateTime?
  matchDuration        Int?             @default(45)
  minRestTime          Int?             @default(30)
  rules                String?
  entryFee             Decimal?         @db.Decimal(10, 2)
  maxParticipants      Int?
  replacementWindowHours Int?           @default(24) // Hours before event start when replacement window closes
  events               Event[]
  organization         Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tournaments")
}

model Event {
  id               String         @id @default(uuid())
  tournamentId     String
  name             String
  format           EventFormat
  maxParticipants  Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  category         String?
  gender           String?
  bracketFormat    BracketFormat?
  bracketGenerated Boolean        @default(false)
  bracketPublished Boolean        @default(false)
  seedingMethod    SeedingMethod?
  registrationFee  Decimal?       @db.Decimal(10, 2)
  rules            String?
  byeCount         Int?
  totalRounds      Int?
  totalSlots       Int?
  // Round Robin & Hybrid fields
  groupSize        Int?           // target participants per group (e.g. 4)
  groupCount       Int?           // actual number of groups created
  advanceCount     Int?           // top N per group advance to knockout (hybrid only)
  hasBronzeMatch   Boolean?       @default(false) // whether to include 3rd place match (hybrid only)
  // Scoring configuration
  sportId          String?        // Sport identifier (badminton, table-tennis, squash, pickleball, tennis, padel)
  scoringType      String?        // "point-based" or "game-set-match" (for tennis/padel)
  scoringRules     Json?          // Full rules object from sports-rules.json
  goldenPoint      Boolean?       @default(false) // Padel only: use golden point rule instead of deuce (40-40 → next point wins)
  bestOf           Int?           // Best of N (e.g., 3 or 5 sets/games) - kept for backward compatibility
  pointsPerSet     Int?           // Points to win a set (e.g., 21 for badminton, 11 for table tennis) - kept for backward compatibility
  tournament       Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches          Match[]
  registrations    Registration[]
  groups           Group[]

  @@map("events")
}

model Group {
  id        String           @id @default(uuid())
  eventId   String
  name      String           // "Group A", "Group B" ...
  status    GroupStatus      @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  matches   Match[]
  standings GroupStanding[]

  @@map("groups")
}

model GroupStanding {
  id             String       @id @default(uuid())
  groupId        String
  registrationId String
  wins           Int          @default(0)
  losses         Int          @default(0)
  draws          Int          @default(0)
  points         Int          @default(0)
  matchesPlayed  Int          @default(0)
  gamesWon       Int          @default(0)  // for game difference
  gamesLost      Int          @default(0)  // for game difference
  pointsFor      Int          @default(0)  // for point difference
  pointsAgainst  Int          @default(0)  // for point difference
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  group          Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([groupId, registrationId])
  @@map("group_standings")
}

model Registration {
  id             String          @id @default(uuid())
  userId         String
  eventId        String
  partnerId      String?
  teamName       String?         // Team name for doubles/mixed doubles
  playerId       String?         // Unique player ID for this event (e.g., "P001", "P002")
  status         RegistrationStatus @default(CONFIRMED)
  registrationOrder Int?          // Order of registration (for seeding)
  isStandby      Boolean         @default(false) // Whether this is a standby registration
  standbyPosition Int?           // Position in standby queue (1, 2, 3...)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  seedNumber     Int?
  isWithdrawn    Boolean         @default(false)
  withdrawnAt    DateTime?
  withdrawalReason String?       // Optional reason for withdrawal
  matchesAsP1    Match[]         @relation("Match_Participant1")
  matchesAsP2    Match[]         @relation("Match_Participant2")
  matchesWon     Match[]         @relation("Match_Winner")
  groupStandings GroupStanding[]
  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  partner        User?           @relation("PartnerRegistrations", fields: [partnerId], references: [id])
  user           User            @relation("UserRegistrations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("registrations")
}

model Match {
  id              String               @id @default(uuid())
  eventId         String
  roundNumber     Int
  matchNumber     Int
  bracketPosition String?
  participant1Id  String?
  participant2Id  String?
  winnerId        String?
  score           String?
  status          MatchStatus          @default(PENDING)
  nextMatchId     String?
  feedsPosition   Int?
  isByeMatch      Boolean              @default(false)
  isWalkover      Boolean              @default(false)
  scheduledAt     DateTime?
  actualStartTime DateTime?
  completedAt     DateTime?
  courtNumber     Int?
  courtName       String?
  duration        Int?
  notes           String?
  pointHistory    String?              // JSON string of point-by-point history for live scoring
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  // Round Robin: groupId is set for group stage matches, null for knockout
  groupId         String?
  event           Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  group           Group?               @relation(fields: [groupId], references: [id])
  participant1    Registration?        @relation("Match_Participant1", fields: [participant1Id], references: [id])
  participant2    Registration?        @relation("Match_Participant2", fields: [participant2Id], references: [id])
  winner          Registration?        @relation("Match_Winner", fields: [winnerId], references: [id])
  ratingChanges   MatchRatingChange[]

  @@unique([eventId, roundNumber, matchNumber])
  @@index([nextMatchId])
  @@index([status])
  @@index([scheduledAt])
  @@index([actualStartTime])
  @@index([groupId])
  @@map("matches")
}

enum BracketFormat {
  SINGLE_ELIMINATION
  ROUND_ROBIN
  LEAGUE_CUM_KNOCKOUT
}

enum SeedingMethod {
  REGISTRATION_ORDER
  RANDOM
  MANUAL
  SNAKE
}

enum GroupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum TournamentFormat {
  BRACKET
  ROUND_ROBIN
  KNOCKOUT
  LEAGUE
}

enum TournamentStatus {
  DRAFT
  OPEN
  CLOSED
  ONGOING
  COMPLETED
}

enum EventFormat {
  SINGLES
  DOUBLES
  MIXED_DOUBLES
}

enum RegistrationStatus {
  CONFIRMED
  STANDBY
  WITHDRAWN
  CANCELLED
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  WALKOVER
  BYE
  READY
  CANCELLED
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
}

model Notification {
  id         String               @id @default(uuid())
  userId     String
  type       String               // Flexible string, not enum
  title      String
  message    String
  data       Json?                // Flexible JSON for any extra data
  actionUrl  String?
  actionText String?
  icon       String?              // Icon name
  priority   NotificationPriority @default(MEDIUM)
  read       Boolean              @default(false)
  createdAt  DateTime             @default(now())
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model LiveFeedItem {
  id         String   @id @default(uuid())
  type       String   // e.g., "PLAYER_REGISTERED", "TOURNAMENT_CREATED"
  actorId    String   // User who performed the action
  title      String
  message    String
  data       Json?    // Flexible JSON
  targetId   String?  // Tournament/Event/Match ID
  targetType String?  // "tournament", "event", "match"
  visibility String   @default("public") // "public", "followers", "city"
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([visibility])
  @@map("live_feed")
}

model PlayerRating {
  id            String              @id @default(uuid())
  userId        String
  sportId       String              // "badminton", "tennis", "table-tennis", etc.
  rating        Float               @default(1200.0) // Glicko-2 rating
  rd            Float               @default(350.0)  // Rating Deviation (uncertainty)
  volatility    Float               @default(0.06)   // Volatility (rating consistency)
  matchCount    Int                 @default(0)      // Total matches played for this sport
  lastMatchDate DateTime?           // Last match played for this sport
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  ratingChanges MatchRatingChange[]

  @@unique([userId, sportId])
  @@index([sportId])
  @@index([rating])
  @@map("player_ratings")
}

model MatchRatingChange {
  id            String        @id @default(uuid())
  matchId       String
  userId        String
  sportId       String
  oldRating     Float
  newRating     Float
  ratingChange  Float         // Positive or negative
  oldRd         Float
  newRd         Float
  oldVolatility Float
  newVolatility Float
  createdAt     DateTime      @default(now())
  match         Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerRating  PlayerRating? @relation(fields: [userId, sportId], references: [userId, sportId], onDelete: Cascade)

  @@index([matchId])
  @@index([userId])
  @@map("match_rating_changes")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  status      String   @default("pending") // pending, accepted, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([status])
  @@map("follows")
}
