generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(uuid())
  firstName            String
  lastName             String
  email                String         @unique
  passwordHash         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  googleId             String?        @unique
  authProvider         String         @default("local")
  dob                  DateTime?
  gender               String?
  onboardingComplete   Boolean        @default(false)
  bio                  String?
  city                 String?
  phone                String?
  profilePicture       String?
  primaryRole          String?
  sports               String[]       @default([])
  orgMemberships       OrgMember[]
  partnerRegistrations Registration[] @relation("PartnerRegistrations")
  registrations        Registration[] @relation("UserRegistrations")

  @@map("users")
}

model Organization {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  logoUrl     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     OrgMember[]
  tournaments Tournament[]

  @@map("organizations")
}

model OrgMember {
  id        String       @id @default(uuid())
  userId    String
  orgId     String
  role      OrgRole      @default(MEMBER)
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("org_members")
}

model Tournament {
  id                   String           @id @default(uuid())
  organizationId       String
  name                 String
  sport                String           // Legacy field - kept for backward compatibility
  sportType            String?          // "single" or "multi"
  sports               String[]         // Array of sport IDs (e.g., ["badminton", "table-tennis"])
  startDate            DateTime
  endDate              DateTime
  venueName            String
  venueAddress         String?
  city                 String
  registrationDeadline DateTime
  description          String?
  status               TournamentStatus @default(DRAFT)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  format               TournamentFormat @default(BRACKET)
  breakDuration        Int?             @default(15)
  courtsAvailable      Int?             @default(4)
  dailyEndTime         String?
  dailyStartTime       String?
  firstMatchDate       DateTime?
  matchDuration        Int?             @default(45)
  minRestTime          Int?             @default(30)
  rules                String?
  entryFee             Decimal?         @db.Decimal(10, 2)
  maxParticipants      Int?
  events               Event[]
  organization         Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tournaments")
}

model Event {
  id               String         @id @default(uuid())
  tournamentId     String
  name             String
  format           EventFormat
  maxParticipants  Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  category         String?
  gender           String?
  bracketFormat    BracketFormat?
  bracketGenerated Boolean        @default(false)
  seedingMethod    SeedingMethod?
  registrationFee  Decimal?       @db.Decimal(10, 2)
  rules            String?
  byeCount         Int?
  totalRounds      Int?
  totalSlots       Int?
  // Round Robin & Hybrid fields
  groupSize        Int?           // target participants per group (e.g. 4)
  groupCount       Int?           // actual number of groups created
  advanceCount     Int?           // top N per group advance to knockout (hybrid only)
  hasBronzeMatch   Boolean?       @default(false) // whether to include 3rd place match (hybrid only)
  // Scoring configuration
  sportId          String?        // Sport identifier (badminton, table-tennis, squash, pickleball)
  scoringType      String?        // "point-based" or "game-set-match" (for tennis/padel later)
  scoringRules     Json?          // Full rules object from sports-rules.json
  bestOf           Int?           // Best of N (e.g., 3 or 5 sets/games) - kept for backward compatibility
  pointsPerSet     Int?           // Points to win a set (e.g., 21 for badminton, 11 for table tennis) - kept for backward compatibility
  tournament       Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches          Match[]
  registrations    Registration[]
  groups           Group[]

  @@map("events")
}

model Group {
  id        String           @id @default(uuid())
  eventId   String
  name      String           // "Group A", "Group B" ...
  status    GroupStatus      @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  matches   Match[]
  standings GroupStanding[]

  @@map("groups")
}

model GroupStanding {
  id             String       @id @default(uuid())
  groupId        String
  registrationId String
  wins           Int          @default(0)
  losses         Int          @default(0)
  draws          Int          @default(0)
  points         Int          @default(0)
  matchesPlayed  Int          @default(0)
  gamesWon       Int          @default(0)  // for game difference
  gamesLost      Int          @default(0)  // for game difference
  pointsFor      Int          @default(0)  // for point difference
  pointsAgainst  Int          @default(0)  // for point difference
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  group          Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([groupId, registrationId])
  @@map("group_standings")
}

model Registration {
  id             String          @id @default(uuid())
  userId         String
  eventId        String
  partnerId      String?
  status         RegistrationStatus @default(CONFIRMED)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  seedNumber     Int?
  isWithdrawn    Boolean         @default(false)
  withdrawnAt    DateTime?
  matchesAsP1    Match[]         @relation("Match_Participant1")
  matchesAsP2    Match[]         @relation("Match_Participant2")
  matchesWon     Match[]         @relation("Match_Winner")
  groupStandings GroupStanding[]
  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  partner        User?           @relation("PartnerRegistrations", fields: [partnerId], references: [id])
  user           User            @relation("UserRegistrations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("registrations")
}

model Match {
  id              String        @id @default(uuid())
  eventId         String
  roundNumber     Int
  matchNumber     Int
  bracketPosition String?
  participant1Id  String?
  participant2Id  String?
  winnerId        String?
  score           String?
  status          MatchStatus   @default(PENDING)
  nextMatchId     String?
  feedsPosition   Int?
  isByeMatch      Boolean       @default(false)
  isWalkover      Boolean       @default(false)
  scheduledAt     DateTime?
  completedAt     DateTime?
  courtNumber     Int?
  courtName       String?
  duration        Int?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  // Round Robin: groupId is set for group stage matches, null for knockout
  groupId         String?
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  group           Group?        @relation(fields: [groupId], references: [id])
  participant1    Registration? @relation("Match_Participant1", fields: [participant1Id], references: [id])
  participant2    Registration? @relation("Match_Participant2", fields: [participant2Id], references: [id])
  winner          Registration? @relation("Match_Winner", fields: [winnerId], references: [id])

  @@unique([eventId, roundNumber, matchNumber])
  @@index([nextMatchId])
  @@index([status])
  @@index([scheduledAt])
  @@index([groupId])
  @@map("matches")
}

enum BracketFormat {
  SINGLE_ELIMINATION
  ROUND_ROBIN
  LEAGUE_CUM_KNOCKOUT
}

enum SeedingMethod {
  REGISTRATION_ORDER
  RANDOM
  MANUAL
  SNAKE
}

enum GroupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum TournamentFormat {
  BRACKET
  ROUND_ROBIN
  KNOCKOUT
  LEAGUE
}

enum TournamentStatus {
  DRAFT
  OPEN
  CLOSED
  ONGOING
  COMPLETED
}

enum EventFormat {
  SINGLES
  DOUBLES
  MIXED_DOUBLES
}

enum RegistrationStatus {
  CONFIRMED
  CANCELLED
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  WALKOVER
  BYE
  READY
  CANCELLED
}
